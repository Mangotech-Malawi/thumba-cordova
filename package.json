{
  "name": "app.thumba.org",
  "displayName": "Thumba",
  "version": "1.0.0",
  "description": "ERP Microfinance System.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Senzenjani Manjawira",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova-android": "^14.0.1",
    "cordova-electron": "^4.0.0",
    "eletron": "^0.0.1-security"
  },
  "cordova": {
    "platforms": [
      "android",
      "electron"
    ]
  },
  "build": {
    "appId": "com.thumba.app",
    "productName": "Thumba",
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
